# Firebase web app configuration
# Copy this file to `.env.local` for local dev, or configure these as
# repository secrets in GitHub Actions for CI/CD.
#
# Find these values in:
#   Firebase Console → Project settings → Your apps → Web app config
#
# All variables are optional — leave them unset to disable cloud sync and
# fall back to a purely local experience.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
